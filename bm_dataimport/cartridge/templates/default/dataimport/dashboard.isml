<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Import Tool</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.3.2/papaparse.min.js"></script>
    <style>
        body { font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }
        .file-drop-zone { transition: background-color 0.2s ease-in-out, border-color 0.2s ease-in-out; }
        .file-drop-zone-active { background-color: #e0e7ff; border-color: #4f46e5; }
        .attr-chip { display:inline-flex; align-items:center; gap:4px; background:#e0e7ff; color:#3730a3;
                     border-radius:9999px; padding:2px 10px; font-size:12px; cursor:pointer; user-select:none; }
        .attr-chip.selected { background:#4f46e5; color:#fff; }
        .attr-chip:hover { opacity:0.85; }
    </style>
</head>
<body class="bg-slate-50 text-slate-800">
<div class="container mx-auto px-4 py-8 max-w-4xl">

    <header class="text-center mb-8">
        <h1 class="text-3xl font-bold text-slate-900">Data Import Tool</h1>
        <p class="mt-1 text-slate-500">Generate import-ready XML directly from your live catalog schema.</p>
    </header>

    <!-- Step 1 -->
    <section class="bg-white p-6 rounded-2xl shadow border border-slate-200 mb-6 fade-in">
        <h2 class="text-xl font-bold mb-4 text-slate-900">Step 1. Select Import Type</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-slate-200 bg-slate-50 cursor-pointer hover:bg-white transition-colors">
                <input type="radio" name="objectType" value="Product" class="h-4 w-4 text-indigo-600">
                <div>
                    <div class="font-medium text-slate-800 text-sm">Product Attributes</div>
                    <div class="text-xs text-slate-500">System &amp; custom product attributes</div>
                </div>
            </label>
        </div>
    </section>

    <!-- Step 2 -->
    <section id="step2" class="bg-white p-6 rounded-2xl shadow border border-slate-200 mb-6 fade-in hidden">
        <h2 class="text-xl font-bold mb-1 text-slate-900">Step 2. Select Attributes &amp; Generate CSV</h2>
        <p class="text-sm text-slate-500 mb-4">Attributes are loaded live from your Business Manager catalog schema.</p>

        <!-- Loading state -->
        <div id="attrs-loading" class="text-sm text-slate-500 py-4">Loading attributes&hellip;</div>

        <!-- Attribute selection area -->
        <div id="attrs-area" class="hidden">

            <!-- System attributes -->
            <div class="mb-5">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Standard Attributes</h3>
                <div id="system-attrs" class="flex flex-wrap gap-2"></div>
            </div>

            <!-- Custom attributes -->
            <div class="mb-5">
                <h3 class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Custom Attributes</h3>
                <div id="custom-attrs" class="flex flex-wrap gap-2"></div>
                <p id="no-custom-attrs" class="text-xs text-slate-400 hidden">No custom attributes defined for this object type.</p>
            </div>

            <hr class="my-5 border-slate-200">

            <!-- Options -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-5">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Locale <span class="text-slate-400 font-normal">(optional)</span></label>
                    <input id="locale-input" type="text" placeholder="e.g. en-US, fr-FR, default"
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Site ID <span class="text-slate-400 font-normal">(for site-specific attrs)</span></label>
                    <input id="site-id-input" type="text" placeholder="e.g. RefArch"
                           class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none">
                </div>
            </div>

            <div id="selected-count" class="text-sm text-slate-500 mb-4">0 attributes selected</div>

            <button id="generate-csv-btn"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
                    disabled>
                Download CSV Template
            </button>
        </div>
    </section>

    <!-- Step 3 -->
    <section id="step3" class="bg-white p-6 rounded-2xl shadow border border-slate-200 mb-6 fade-in hidden">
        <h2 class="text-xl font-bold mb-4 text-slate-900">Step 3. Upload CSV &amp; Generate XML</h2>

        <div class="mb-4">
            <label class="block text-sm font-medium text-slate-700 mb-1">Catalog ID <span class="text-red-500">*</span></label>
            <input id="catalog-id-input" type="text" placeholder="e.g. storefront-catalog-en"
                   class="w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-300 focus:border-indigo-400 outline-none max-w-sm">
        </div>

        <div id="drop-zone"
             class="file-drop-zone border-2 border-dashed border-slate-300 rounded-xl p-8 text-center cursor-pointer hover:border-indigo-400 hover:bg-indigo-50 transition-colors mb-4">
            <p class="text-slate-500 text-sm">Drag &amp; drop your CSV here, or <span class="text-indigo-600 font-medium">click to browse</span></p>
            <p id="file-name-display" class="mt-2 text-xs text-slate-400"></p>
            <input id="csv-file-input" type="file" accept=".csv" class="hidden">
        </div>

        <div id="csv-status" class="text-sm mb-4 hidden"></div>

        <button id="generate-xml-btn"
                class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold px-5 py-2.5 rounded-lg text-sm transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
                disabled>
            Generate XML
        </button>

        <div id="xml-status" class="text-sm mt-3 hidden"></div>
    </section>

</div><!-- /container -->

<script>
(function () {
    'use strict';

    // ─── State ───────────────────────────────────────────────────────────────
    var allAttributes   = [];   // Full list returned by GetAttributes
    var selectedIds     = {};   // { attrId: true }
    var parsedRows      = null;
    var currentObjType  = null;

    // ─── DOM refs ─────────────────────────────────────────────────────────────
    var step2           = document.getElementById('step2');
    var step3           = document.getElementById('step3');
    var attrsLoading    = document.getElementById('attrs-loading');
    var attrsArea       = document.getElementById('attrs-area');
    var systemAttrsEl   = document.getElementById('system-attrs');
    var customAttrsEl   = document.getElementById('custom-attrs');
    var noCustomEl      = document.getElementById('no-custom-attrs');
    var selectedCountEl = document.getElementById('selected-count');
    var generateCsvBtn  = document.getElementById('generate-csv-btn');
    var generateXmlBtn  = document.getElementById('generate-xml-btn');
    var dropZone        = document.getElementById('drop-zone');
    var csvFileInput    = document.getElementById('csv-file-input');
    var fileNameDisplay = document.getElementById('file-name-display');
    var csvStatus       = document.getElementById('csv-status');
    var xmlStatus       = document.getElementById('xml-status');
    var localeInput     = document.getElementById('locale-input');
    var siteIdInput     = document.getElementById('site-id-input');
    var catalogIdInput  = document.getElementById('catalog-id-input');

    // ─── Step 1: object type selection ───────────────────────────────────────
    document.querySelectorAll('input[name="objectType"]').forEach(function (radio) {
        radio.addEventListener('change', function () {
            currentObjType = this.value;
            selectedIds = {};
            parsedRows = null;
            resetStep3();
            loadAttributes(currentObjType);
            step2.classList.remove('hidden');
            step3.classList.remove('hidden');
        });
    });

    // ─── Attribute loading ────────────────────────────────────────────────────
    function loadAttributes(objectType) {
        attrsLoading.classList.remove('hidden');
        attrsArea.classList.add('hidden');
        systemAttrsEl.innerHTML = '';
        customAttrsEl.innerHTML = '';

        var url = '${URLUtils.url("DataImport-GetAttributes")}?objectType=' + encodeURIComponent(objectType);

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.error) {
                    showError(attrsLoading, 'Failed to load attributes: ' + data.error);
                    return;
                }
                allAttributes = data.attributes || [];
                renderAttributeChips();
                attrsLoading.classList.add('hidden');
                attrsArea.classList.remove('hidden');
            })
            .catch(function (err) {
                showError(attrsLoading, 'Network error loading attributes: ' + err.message);
            });
    }

    function renderAttributeChips() {
        systemAttrsEl.innerHTML = '';
        customAttrsEl.innerHTML = '';
        var hasCustom = false;

        allAttributes.forEach(function (attr) {
            var chip = document.createElement('span');
            chip.className = 'attr-chip' + (selectedIds[attr.id] ? ' selected' : '');
            chip.dataset.id = attr.id;
            chip.title = attr.type + (attr.mandatory ? ' — mandatory' : '') +
                         (attr.siteSpecific ? ' — site-specific' : '') +
                         (attr.localizable ? ' — localizable' : '');

            var label = document.createTextNode(attr.displayName);
            chip.appendChild(label);

            if (attr.mandatory) {
                var badge = document.createElement('span');
                badge.textContent = '*';
                badge.className = 'text-red-300 font-bold';
                chip.appendChild(badge);
            }

            chip.addEventListener('click', function () {
                toggleAttribute(attr.id);
                chip.classList.toggle('selected', !!selectedIds[attr.id]);
                updateSelectedCount();
            });

            if (attr.system) {
                systemAttrsEl.appendChild(chip);
            } else {
                customAttrsEl.appendChild(chip);
                hasCustom = true;
            }
        });

        noCustomEl.classList.toggle('hidden', hasCustom);
        updateSelectedCount();
    }

    function toggleAttribute(id) {
        if (selectedIds[id]) {
            delete selectedIds[id];
        } else {
            selectedIds[id] = true;
        }
    }

    function updateSelectedCount() {
        var count = Object.keys(selectedIds).length;
        selectedCountEl.textContent = count + ' attribute' + (count === 1 ? '' : 's') + ' selected';
        generateCsvBtn.disabled = count === 0;
    }

    // ─── Step 2: CSV generation ───────────────────────────────────────────────
    generateCsvBtn.addEventListener('click', function () {
        var headers = ['product-id'];
        allAttributes.forEach(function (attr) {
            if (selectedIds[attr.id]) {
                headers.push(attr.system ? attr.xmlElement : attr.id);
            }
        });

        var csvContent = headers.map(function (h) { return '"' + h + '"'; }).join(',') + '\r\n';
        var blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = 'product-import-template-' + timestamp() + '.csv';
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    });

    // ─── Step 3: CSV upload ───────────────────────────────────────────────────
    dropZone.addEventListener('click', function () { csvFileInput.click(); });

    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.classList.add('file-drop-zone-active');
    });
    dropZone.addEventListener('dragleave', function () {
        dropZone.classList.remove('file-drop-zone-active');
    });
    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.classList.remove('file-drop-zone-active');
        var file = e.dataTransfer.files[0];
        if (file) handleFile(file);
    });
    csvFileInput.addEventListener('change', function () {
        if (this.files[0]) handleFile(this.files[0]);
    });

    function handleFile(file) {
        fileNameDisplay.textContent = file.name;
        csvStatus.classList.remove('hidden');
        csvStatus.className = 'text-sm mb-4 text-slate-500';
        csvStatus.textContent = 'Parsing CSV…';
        generateXmlBtn.disabled = true;
        parsedRows = null;

        Papa.parse(file, {
            header: true,
            skipEmptyLines: true,
            complete: function (results) {
                if (!results.data || results.data.length === 0) {
                    csvStatus.className = 'text-sm mb-4 text-red-600';
                    csvStatus.textContent = 'CSV appears to be empty.';
                    return;
                }
                parsedRows = results.data;
                csvStatus.className = 'text-sm mb-4 text-emerald-600';
                csvStatus.textContent = parsedRows.length + ' row' + (parsedRows.length === 1 ? '' : 's') + ' loaded.';
                generateXmlBtn.disabled = false;
            },
            error: function (err) {
                csvStatus.className = 'text-sm mb-4 text-red-600';
                csvStatus.textContent = 'Parse error: ' + err.message;
            }
        });
    }

    // ─── Step 3: XML generation ───────────────────────────────────────────────
    generateXmlBtn.addEventListener('click', function () {
        var catalogId = catalogIdInput.value.trim();
        if (!catalogId) {
            catalogIdInput.classList.add('border-red-500');
            setTimeout(function () { catalogIdInput.classList.remove('border-red-500'); }, 3000);
            showXmlStatus('error', 'Please enter a Catalog ID.');
            return;
        }
        if (!parsedRows || parsedRows.length === 0) {
            showXmlStatus('error', 'No CSV data to convert.');
            return;
        }

        try {
            var xml = buildProductXml(catalogId);
            downloadXml(xml, 'product-import-' + timestamp() + '.xml');
            showXmlStatus('ok', 'XML generated successfully.');
        } catch (e) {
            showXmlStatus('error', 'Error generating XML: ' + e.message);
        }
    });

    // ─── XML builder (Product Attributes) ────────────────────────────────────
    var PRODUCT_ELEMENT_ORDER = [
        'ean', 'upc', 'unit', 'unit-quantity', 'unit-measure',
        'min-order-quantity', 'step-quantity',
        'display-name', 'short-description', 'long-description', 'store-receipt-name',
        'online-flag', 'online-from', 'online-to', 'available-flag',
        'searchable-flag', 'searchable-if-unavailable-flag',
        'images', 'image', 'thumbnail', 'template',
        'tax-class-id', 'localized-tax-class-id',
        'brand', 'manufacturer-name', 'manufacturer-sku',
        'search-placement', 'search-rank',
        'sitemap-included-flag', 'sitemap-changefrequency', 'sitemap-priority',
        'page-attributes', 'custom-attributes',
        'bundled-products', 'retail-set-products', 'product-set-products',
        'options', 'variations', 'product-links', 'category-links',
        'classification-category',
        'pinterest-enabled-flag', 'facebook-enabled-flag'
    ];

    var PAGE_ATTR_NAMES  = ['page-title', 'page-description', 'page-keywords', 'page-url'];
    var PAGE_ATTR_SOURCE = ['pageTitle', 'pageDescription', 'pageKeywords', 'pageURL']; // fallback CSV header names

    function buildProductXml(catalogId) {
        var locale  = normalizeLocale(localeInput.value.trim() || 'default');
        var siteId  = siteIdInput.value.trim();

        // Build a quick lookup: xmlElement -> attr descriptor
        var attrByElement = {};
        var attrById      = {};
        allAttributes.forEach(function (a) {
            attrByElement[a.xmlElement] = a;
            attrById[a.id] = a;
        });

        var itemsXml = '';

        parsedRows.forEach(function (row) {
            var productId = (row['product-id'] || row['Product ID'] || '').trim();
            if (!productId) return;

            var standardEls  = [];
            var pageEls      = [];
            var customEls    = [];

            // Classify each CSV column
            Object.keys(row).forEach(function (col) {
                if (col === 'product-id' || col === 'Product ID') return;

                var val  = row[col];
                var attr = attrByElement[col] || attrById[col];

                if (!attr) {
                    // Unknown column — treat as custom attribute, use column name as attribute-id
                    if (val !== undefined) {
                        customEls.push({ id: col, value: val });
                    }
                    return;
                }

                if (!attr.system) {
                    customEls.push({ id: attr.id, value: val || '' });
                    return;
                }

                // System attribute
                var el = attr.xmlElement;
                if (PAGE_ATTR_NAMES.indexOf(el) !== -1) {
                    pageEls.push({ el: el, attr: attr, value: val || '' });
                } else {
                    standardEls.push({ el: el, attr: attr, value: val || '' });
                }
            });

            // Sort standard elements by schema order
            standardEls.sort(function (a, b) {
                var ia = PRODUCT_ELEMENT_ORDER.indexOf(a.el);
                var ib = PRODUCT_ELEMENT_ORDER.indexOf(b.el);
                return (ia === -1 ? 9999 : ia) - (ib === -1 ? 9999 : ib);
            });
            pageEls.sort(function (a, b) {
                return PAGE_ATTR_NAMES.indexOf(a.el) - PAGE_ATTR_NAMES.indexOf(b.el);
            });

            var content = '';
            var pageInserted = false;
            var pageAttrPos  = PRODUCT_ELEMENT_ORDER.indexOf('page-attributes');

            standardEls.forEach(function (item) {
                if (!pageInserted && pageEls.length > 0) {
                    var pos = PRODUCT_ELEMENT_ORDER.indexOf(item.el);
                    if (pos > pageAttrPos || pos === -1) {
                        content += buildPageAttributes(pageEls, locale, siteId);
                        pageInserted = true;
                    }
                }
                content += buildStandardElement(item.el, item.attr, item.value, locale, siteId);
            });

            if (!pageInserted && pageEls.length > 0) {
                content += buildPageAttributes(pageEls, locale, siteId);
            }

            if (customEls.length > 0) {
                content += '\n        <custom-attributes>';
                customEls.forEach(function (c) {
                    var attrDesc = attrById[c.id];
                    var type     = attrDesc ? attrDesc.type : 'String';
                    var isLoc    = attrDesc ? attrDesc.localizable : false;
                    var isSite   = attrDesc ? attrDesc.siteSpecific : false;
                    var fVal     = formatValue(c.value, type);
                    var attrStr  = ' attribute-id="' + escapeXml(c.id) + '"';
                    if (isLoc && locale !== 'default') attrStr += ' xml:lang="' + escapeXml(locale) + '"';
                    if (isSite && siteId) attrStr += ' site-id="' + escapeXml(siteId) + '"';
                    content += '\n            <custom-attribute' + attrStr + '>' + xmlValue(fVal, isLoc ? locale : null) + '</custom-attribute>';
                });
                content += '\n        </custom-attributes>';
            }

            itemsXml += '\n    <product product-id="' + escapeXml(productId) + '">' + content + '\n    </product>';
        });

        return '<?xml version="1.0" encoding="UTF-8"?>\n' +
               '<catalog xmlns="http://www.demandware.com/xml/impex/catalog/2006-10-31" catalog-id="' + escapeXml(catalogId) + '">' +
               itemsXml +
               '\n</catalog>';
    }

    function buildStandardElement(el, attr, value, locale, siteId) {
        var fVal     = formatValue(value, attr.type);
        var isLoc    = attr.localizable;
        var isSite   = attr.siteSpecific;
        var attrStr  = '';
        if (isLoc && locale !== 'default') attrStr += ' xml:lang="' + escapeXml(locale) + '"';
        if (isSite && siteId) attrStr += ' site-id="' + escapeXml(siteId) + '"';
        return '\n        <' + el + attrStr + '>' + xmlValue(fVal, isLoc ? locale : null) + '</' + el + '>';
    }

    function buildPageAttributes(pageEls, locale, siteId) {
        var out = '\n        <page-attributes>';
        pageEls.forEach(function (item) {
            var fVal    = formatValue(item.value, item.attr.type);
            var attrStr = '';
            if (locale !== 'default') attrStr += ' xml:lang="' + escapeXml(locale) + '"';
            if (siteId) attrStr += ' site-id="' + escapeXml(siteId) + '"';
            out += '\n            <' + item.el + attrStr + '>' + xmlValue(fVal, locale !== 'default' ? locale : null) + '</' + item.el + '>';
        });
        out += '\n        </page-attributes>';
        return out;
    }

    // ─── Value formatting ─────────────────────────────────────────────────────
    function formatValue(value, type) {
        if (value === null || value === undefined || value === '') return value;
        var v = value.toString();
        switch (type) {
            case 'Boolean':
                var b = v.toLowerCase().trim();
                if (b === 'true' || b === '1' || b === 'yes' || b === 'y' || b === 'on')  return 'true';
                if (b === 'false'|| b === '0' || b === 'no'  || b === 'n' || b === 'off') return 'false';
                return 'false';
            case 'Date':
                try { var d = new Date(v); if (!isNaN(d)) return d.toISOString().split('T')[0]; } catch(e) {}
                return v;
            case 'Date+Time':
                try { var d2 = new Date(v); if (!isNaN(d2)) return d2.toISOString(); } catch(e) {}
                return v;
            case 'Number':
            case 'Quantity':
                var n = parseFloat(v);
                return isNaN(n) ? v : n.toString();
            case 'Integer':
            case 'Enum of Integers':
                var i = parseInt(v, 10);
                return isNaN(i) ? v : i.toString();
            case 'Set of Strings':
            case 'Set of Integers':
            case 'Set of Numbers':
                return v.includes(',') ? v.split(',').map(function(s){return s.trim();}).join('|') : v;
            default:
                return v;
        }
    }

    function xmlValue(value, locale) {
        if (!value && value !== 0) return '';
        if (locale && locale !== 'default') {
            return '<![CDATA[' + removeInvalidXml(value.toString()) + ']]>';
        }
        return escapeXml(value.toString());
    }

    // ─── XML escape ───────────────────────────────────────────────────────────
    function escapeXml(str) {
        if (!str && str !== 0) return '';
        return str.toString()
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&apos;');
    }

    function removeInvalidXml(str) {
        return str ? str.replace(/[\x00-\x08\x0B-\x0C\x0E-\x1F\x7F-\x9F]/g, '') : '';
    }

    function normalizeLocale(locale) {
        if (!locale || locale === 'default' || locale === 'x-default') return locale;
        var n = locale.replace(/_/g, '-');
        if (n.length === 5 && n.indexOf('-') !== -1) {
            var parts = n.split('-');
            if (parts.length === 2 && parts[0].length === 2 && parts[1].length === 2) {
                return parts[0] + '-' + parts[1].toUpperCase();
            }
        }
        return n;
    }

    // ─── Download helpers ─────────────────────────────────────────────────────
    function downloadXml(content, filename) {
        var blob = new Blob([content], { type: 'application/xml;charset=utf-8;' });
        var url  = URL.createObjectURL(blob);
        var a    = document.createElement('a');
        a.href   = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function timestamp() {
        return new Date().toISOString().replace(/[:\-T]/g, '').slice(0, 14);
    }

    // ─── UI helpers ───────────────────────────────────────────────────────────
    function showXmlStatus(type, msg) {
        xmlStatus.classList.remove('hidden');
        xmlStatus.className = 'text-sm mt-3 ' + (type === 'error' ? 'text-red-600' : 'text-emerald-600');
        xmlStatus.textContent = msg;
    }

    function showError(el, msg) {
        el.className = 'text-sm text-red-600 py-4';
        el.textContent = msg;
        el.classList.remove('hidden');
    }

    function resetStep3() {
        parsedRows = null;
        fileNameDisplay.textContent = '';
        csvStatus.classList.add('hidden');
        xmlStatus.classList.add('hidden');
        generateXmlBtn.disabled = true;
        csvFileInput.value = '';
    }

}());
</script>
</body>
</html>
